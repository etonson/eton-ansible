---
# Example configuration for vars/secrets.yml
# Copy this file to vars/secrets.yml and fill in your actual details before running the playbook.

# Personal Git user info
git_user_name: "John Doe"
git_user_email: "john.doe@example.com"

# Git user info for Ginmao work projects (applied under ~/ginmao-project/)
git_ginmao_name: "John Ginmao"
git_ginmao_email: "john.doe@ginmao.com.tw"

# SSH configuration
ssh_github_identity_file: "~/.ssh/id_ed25519"
ssh_homelab_hostname: "192.168.1.100"
ssh_homelab_user: "your_username"

